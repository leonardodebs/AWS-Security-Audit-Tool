# AWS Credentials (use a profile OR explicit keys, not both)
AWS_PROFILE=

# Or use explicit credentials:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

AWS_DEFAULT_REGION=us-east-1

# Scanner behaviour
UNUSED_KEY_DAYS=90
MAX_WORKERS=5
LOG_LEVEL=INFO

# Output
OUTPUT_DIR=./reports

# Optional: upload reports to S3 after scan
REPORT_S3_BUCKET=

# Optional: SNS topic for email alerts
SNS_TOPIC_ARN=
